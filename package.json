{
  "name": "agent-flow",
  "version": "1.0.0",
  "description": "Monitor and control AI agents (OpenClaw and Hermes) directly from your Ubuntu desktop",
  "author": {
    "name": "AgentFlow Team",
    "email": "support@agentflow.local"
  },
  "license": "MIT",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:deb": "electron-builder --linux deb",
    "build:appimage": "electron-builder --linux AppImage",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "build": {
    "appId": "com.agentflow.app",
    "productName": "AgentFlow",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "service-manager.js",
      "index.html",
      "style.css",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    },
    "deb": {
      "depends": [
        "gconf2",
        "gconf-service",
        "libappindicator1",
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "jest": "^30.3.0"
  }
}
